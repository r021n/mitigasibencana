# ============================================================
# BACKEND ENVIRONMENT VARIABLES - PRODUCTION
# Salin file ini menjadi .env dan isi nilainya di server
# ============================================================

# Port yang didengarkan backend Hono
PORT=3000

# Path absolut ke file SQLite database
# Sesuaikan dengan lokasi deploy di VPS
DB_PATH=/var/www/mitigasibencana/backend/sqlite.db

# JWT Secret - WAJIB diganti dengan string acak yang kuat!
# Generate dengan: openssl rand -base64 64
JWT_SECRET=ganti_dengan_secret_yang_sangat_kuat_dan_acak

# Domain frontend yang diizinkan mengakses API (CORS)
# Pisahkan dengan koma jika ada lebih dari satu
ALLOWED_ORIGINS=https://mitigasibencana.net,https://www.mitigasibencana.net

# API Key Google Gemini - WAJIB diisi untuk fitur analisis video
# Dapatkan dari: https://aistudio.google.com/
GEMINI_API_KEY=[GEMINI_API_KEY]

